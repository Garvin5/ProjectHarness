#!/usr/bin/env bash
# PreToolUse hook: block git commit when native tasks are incomplete
# Only triggers on Bash tool calls containing "git commit".

# No set -e: if anything fails unexpectedly, fall through to allow.
trap 'echo "{\"decision\": \"allow\"}"; exit 0' ERR

INPUT=$(cat)

TOOL_NAME=$(echo "$INPUT" | jq -r '.tool_name // empty')
[[ "$TOOL_NAME" != "Bash" ]] && echo '{"decision": "allow"}' && exit 0

COMMAND=$(echo "$INPUT" | jq -r '.tool_input.command // empty')
echo "$COMMAND" | grep -q 'git commit' || { echo '{"decision": "allow"}'; exit 0; }

TRANSCRIPT_PATH=$(echo "$INPUT" | jq -r '.transcript_path // empty')
[[ -z "$TRANSCRIPT_PATH" || ! -f "$TRANSCRIPT_PATH" ]] && echo '{"decision": "allow"}' && exit 0

OPEN_TASKS=$(python3 -c "
import json
tasks = {}
next_id = 1
for line in open('$TRANSCRIPT_PATH'):
    try: entry = json.loads(line)
    except: continue
    if entry.get('type') != 'assistant': continue
    for c in entry.get('message', {}).get('content', []):
        if c.get('type') != 'tool_use': continue
        name, inp = c.get('name', ''), c.get('input', {})
        if name == 'TaskCreate':
            tasks[str(next_id)] = 'open'
            next_id += 1
        elif name == 'TaskUpdate':
            tid = str(inp.get('taskId', ''))
            status = inp.get('status', '')
            if tid and status:
                tasks[tid] = status
                try:
                    if int(tid) >= next_id: next_id = int(tid) + 1
                except ValueError: pass
print(sum(1 for s in tasks.values() if s not in ('completed', 'cancelled', 'deleted')))
" 2>/dev/null || echo "0")

if [[ "$OPEN_TASKS" -gt 0 ]]; then
    echo "COMMIT BLOCKED: $OPEN_TASKS incomplete native task(s). Finish tasks before committing." >&2
    exit 2
fi

# --- Harness invariant checks (warnings, not blockers) ---
PROJECT_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
WARNINGS=""

# Check 1: Spec coverage — completed features should have specs
if [[ -f "$PROJECT_ROOT/docs/project/roadmap.md" && -d "$PROJECT_ROOT/docs/project/specs" ]]; then
    MISSING_SPECS=$(python3 -c "
import re, os
roadmap = open('$PROJECT_ROOT/docs/project/roadmap.md').read()
# Find completed feat items: - [x] F... [feat, ...]
completed = re.findall(r'- \[x\] (F[\d.]+):.*?\[feat', roadmap)
specs_dir = '$PROJECT_ROOT/docs/project/specs'
spec_files = []
for root, dirs, files in os.walk(specs_dir):
    spec_files.extend(f for f in files if f.endswith('.md') and f != 'index.md')
# Simple heuristic: warn if completed features outnumber spec files significantly
if len(completed) > len(spec_files) + 2:
    print(f'{len(completed)} completed features but only {len(spec_files)} spec files')
else:
    print('')
" 2>/dev/null || echo "")
    [[ -n "$MISSING_SPECS" ]] && WARNINGS="${WARNINGS}\n⚠️  Spec coverage: $MISSING_SPECS"
fi

# Check 2: CLAUDE.md navigation freshness
if [[ -f "$PROJECT_ROOT/CLAUDE.md" && -d "$PROJECT_ROOT/docs/project" ]]; then
    CLAUDE_STALE=$(python3 -c "
claude = open('$PROJECT_ROOT/CLAUDE.md').read()
import os
for f in ['vision.md', 'roadmap.md', 'architecture.md']:
    path = os.path.join('$PROJECT_ROOT/docs/project', f)
    if os.path.exists(path) and f not in claude:
        print(f'CLAUDE.md missing link to docs/project/{f}')
        break
else:
    print('')
" 2>/dev/null || echo "")
    [[ -n "$CLAUDE_STALE" ]] && WARNINGS="${WARNINGS}\n⚠️  $CLAUDE_STALE"
fi

# Output warnings (non-blocking)
if [[ -n "$WARNINGS" ]]; then
    echo -e "Harness invariant warnings:$WARNINGS" >&2
    echo -e "Run /project-health for full check." >&2
fi

echo '{"decision": "allow"}'
exit 0
