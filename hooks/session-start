#!/usr/bin/env bash
# SessionStart hook for AI Development Harness

set -euo pipefail

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Check if legacy skills directory exists and build warning
warning_message=""
legacy_skills_dir="${HOME}/.config/superpowers/skills"
if [ -d "$legacy_skills_dir" ]; then
    warning_message="\n\n<important-reminder>IN YOUR FIRST REPLY AFTER SEEING THIS MESSAGE YOU MUST TELL THE USER:⚠️ **WARNING:** This harness now uses Claude Code's skills system. Custom skills in ~/.config/superpowers/skills will not be read. Move custom skills to ~/.claude/skills instead. To make this message go away, remove ~/.config/superpowers/skills</important-reminder>"
fi

# Read using-harness content
using_harness_content=$(cat "${PLUGIN_ROOT}/skills/using-harness/SKILL.md" 2>&1 || echo "Error reading using-harness skill")

# Escape string for JSON embedding using bash parameter substitution.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

using_harness_escaped=$(escape_for_json "$using_harness_content")
warning_escaped=$(escape_for_json "$warning_message")

# Build harness project context if docs/project exists
harness_context=""
project_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

if [ -f "${project_root}/docs/project/.current-work.md" ]; then
    current_work=$(cat "${project_root}/docs/project/.current-work.md" 2>/dev/null || echo "")
    current_work_escaped=$(escape_for_json "$current_work")
    harness_context="${harness_context}\n\n<current-work>\n${current_work_escaped}\n</current-work>"
fi

if [ -f "${project_root}/docs/project/roadmap.md" ]; then
    # Inject just the first 80 lines (milestones + top modules) as summary
    roadmap_summary=$(head -80 "${project_root}/docs/project/roadmap.md" 2>/dev/null || echo "")
    roadmap_escaped=$(escape_for_json "$roadmap_summary")
    harness_context="${harness_context}\n\n<roadmap-summary>\n${roadmap_escaped}\n</roadmap-summary>"
fi

if [ -f "${project_root}/docs/project/architecture.md" ]; then
    # Inject architecture section headers as a map
    arch_summary=$(grep -E '^#{1,3} ' "${project_root}/docs/project/architecture.md" 2>/dev/null || echo "")
    arch_escaped=$(escape_for_json "$arch_summary")
    harness_context="${harness_context}\n\n<architecture-outline>\n${arch_escaped}\n</architecture-outline>"
fi

session_context="<EXTREMELY_IMPORTANT>\nYou have an AI Development Harness installed.\n\n**Below is the full content of your 'using-harness' skill - your introduction to using skills. For all other skills, use the 'Skill' tool:**\n\n${using_harness_escaped}\n\n${warning_escaped}${harness_context}\n</EXTREMELY_IMPORTANT>"

# Output context injection as JSON.
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
fi

exit 0
